<header class="app-header">
  <div class="header-container">
    <div class="header-left">
      <%# ログインしているときだけ、左側のメニューを表示する %>
      <% if current_user %>
        <div class="filter-buttons">
          <%# いま「完了済(filter=completed)」を開いていたら、その記憶を引き継いでTEAMにする %>
          <%= link_to "TEAM", tasks_path(scope: :team, filter: params[:filter]), class: "filter-button #{'active' if params[:scope] == 'team'}" %>
          <%# MYに戻る時も、いまのfilterの記憶を引き継ぐ %>
          <%= link_to "MY", tasks_path(filter: params[:filter]), class: "filter-button #{'active' if params[:scope] != 'team'}" %>
        </div>
        <nav class="header-nav">
          <%= link_to "タスク作成", new_task_path, class: "header-link" %>|
          <%# 一覧を移動するときも、いまの「TEAMかMYか(scope)」の記憶を引き継ぐ %>
          <%= link_to "タスク一覧", tasks_path(scope: params[:scope]), class: "header-link" %>|
          <%= link_to "完了済タスク一覧", tasks_path(filter: :completed, scope: params[:scope]), class: "header-link" %>
        </nav>
      <% else %>
        <nav class="header-nav">
          <%= link_to "新規登録", signup_path, class: "header-link" %>|
          <%= link_to "ログイン", login_path, class: "header-link" %>
        </nav>
      <% end %>
    </div>

    <div class="header-right">
      <span class="header-date">
        <%= Time.current.strftime("%Y年 %m月 %d日") %> (<%= %w(日 月 火 水 木 金 土)[Time.current.wday] %>)
      </span>

      <span class="header-user">
        <% if current_user %>
          <%= current_user.name %>
        <% else %>
          ゲストさん
        <% end %>
      </span>

      <%# ログインしているときだけ、三点リーダーメニューを表示する %>
      <% if current_user %>
        <div class="header-menu" data-controller="menu" data-action="click@window->menu#close">
          <button class="menu-trigger" data-action="click->menu#toggle">⋮</button>
          <div class="dropdown-menu" data-menu-target="dropdown">
            <%= link_to "個人設定", profile_path, class: "dropdown-item" %>
            
            <%# 管理者の場合のみ「管理者設定」を表示 %>
            <% if current_user.admin? %>
              <%= link_to "管理者設定", admin_settings_path, class: "dropdown-item" %>
            <% end %>
            
            <%= link_to "ログアウト", logout_path, data: { turbo_method: :delete }, class: "dropdown-item logout" %>
          </div>
          </div>
        </div>
      <% end %>
      
    </div>
  </div>
</header>