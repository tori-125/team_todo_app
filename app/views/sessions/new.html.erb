<h1 class="title-lg">ログイン</h1>

<div class="task-form">
  <%# ログイン失敗時のエラーメッセージを表示する場所 %>
  <% if flash[:alert] %>
    <div class="error-summary">
      <p><%= flash[:alert] %></p>
    </div>
  <% end %>

  <%= form_with url: login_path, local: true do |f| %>
    <div class="form-group">
      <%= f.label :email, "メールアドレス" %>
      <%= f.email_field :email, class: "form-input", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :password, "パスワード" %>
      <%= f.password_field :password, class: "form-input", required: true %>
    </div>

    <%# ログイン保持のチェックボックスを追加 %>
    <div class="form-group remember-me-group">
      <%= f.check_box :remember_me, class: "form-checkbox" %>
      <%= f.label :remember_me, "ログイン状態を保持する", class: "form-checkbox-label" %>
    </div>

    <div class="form-group" style="margin-top: 30px;">
      <%= f.submit "ログイン", class: "btn submit-btn" %>
    </div>
  <% end %>
</div>